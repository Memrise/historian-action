{
  "name": "historian-action",
  "version": "0.0.0",
  "private": true,
  "description": "Collects changes between two revisions",
  "main": "src/main.js",
  "scripts": {
    "build": "ncc build src/main.js",
    "format": "prettier --write '**/*.js'",
    "format-check": "prettier --check '**/*.js'",
    "lint": "eslint src/*.js",
    "all": "npm run format && npm run lint && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Memrise/historian-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "Memrise",
  "license": "Apache-2.0",
  "type": "module",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "pupa": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^10.0.3",
    "prettier": "3.8.3"
  }
}
